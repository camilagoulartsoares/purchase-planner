PORT=3334
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# PostgreSQL (Docker): docker compose up -d postgres
DATABASE_URL="postgresql://closet:closet@localhost:5433/closet_sonhos?schema=public&connection_limit=3&pool_timeout=10&connect_timeout=10"

JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio
JWT_EXPIRES_IN=7d

# Fotos na nuvem — conta grátis: https://cloudinary.com
# Sem isso, fotos ficam no volume Docker (closet_uploads) / pasta data/uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=closet-sonhos

MELI_CLIENT_ID=
MELI_CLIENT_SECRET=
MELI_REDIRECT_URI=
MELI_TOKEN_ENCRYPTION_KEY=

MAX_FILE_SIZE_MB=8
