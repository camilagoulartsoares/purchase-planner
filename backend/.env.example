PORT=3334
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# SQLite local — arquivo fica em backend/prisma/dev.db (sem Docker)
DATABASE_URL="file:./dev.db"

JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio
JWT_EXPIRES_IN=7d

# Cloudinary (opcional em casa). Sem isso, a foto fica salva em base64 no banco.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=closet-sonhos

MAX_FILE_SIZE_MB=5
