generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  products     Product[]
  brands       Brand[]
}

model Brand {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@unique([userId, name])
  @@unique([userId, slug])
  @@index([userId])
}

model Product {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandId          String
  brand            Brand          @relation(fields: [brandId], references: [id], onDelete: Restrict)
  name             String
  category         String
  store            String
  originalPrice    Decimal
  promotionalPrice Decimal?
  purchaseUrl      String?
  imageUrl         String?
  imagePublicId    String?
  color            String?
  size             String?
  priority         String         @default("Quero")
  status           String         @default("Quero comprar")
  notes            String?
  purchasedPrice   Decimal?
  purchasedAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  images           ProductImage[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, category])
  @@index([brandId])
}

model ProductImage {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  imageUrl      String
  imagePublicId String
  position      Int      @default(0)
  isMain        Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([productId])
  @@index([productId, position])
}
